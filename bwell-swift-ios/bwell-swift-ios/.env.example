# b.well SDK Example App Configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will NOT be committed. Never commit real keys.

# --- App credentials (read by the app via EnvConfig) ---

# Client key (base64-encoded JSON with environment config). Obtain from your b.well contact.
BWELL_CLIENT_KEY=

# A pre-generated JWT for OAuth authentication.
# Optional if you mint one locally via the steps in TESTING.md.
BWELL_JWT_TOKEN=

# --- Local-only values for minting a dev JWT (see TESTING.md "Authentication") ---
# Used only by the local JWT-signing helper. Keep these on your machine; never commit them.

# Absolute path to your LOCAL EC (ES256) private signing key, obtained from the
# bwell-identity-gateway maintainers. Do NOT place the key file inside this repo.
BWELL_DEV_SIGNING_KEY_PATH=

# The key id (kid) the identity gateway trusts for your dev signing key.
BWELL_DEV_SIGNING_KID=

# The test identity GUID for your seeded sandbox user.
BWELL_DEV_GUID=
